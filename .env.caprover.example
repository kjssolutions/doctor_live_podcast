# Copy these into CapRover → App → App Configs → Environment Variables
# Replace placeholder values before deploying.

# --- App ---
NODE_ENV=production
PORT=3000

# Public URL of your app (HTTPS, no trailing slash)
NEXTAUTH_URL=https://doctor-podcast.yourdomain.com
NEXTAUTH_SECRET=generate-a-long-random-secret-at-least-32-chars

# --- MySQL / MariaDB (DigitalOcean managed DB or droplet) ---
MYSQL_HOST=your-db-host.db.ondigitalocean.com
MYSQL_PORT=25060
MYSQL_USER=doadmin
MYSQL_PASSWORD=your-db-password
MYSQL_DB=doctor_live_podcast
# Set true for DigitalOcean managed MySQL
MYSQL_SSL=true
# Optional fallback if DNS intermittently fails on server/machine:
# MYSQL_HOST_IP=143.110.178.227

# Optional: single connection string instead of MYSQL_* above
# DATABASE_URL=mysql://user:password@host:25060/doctor_live_podcast?sslaccept=accept_invalid_certs

# --- DigitalOcean Spaces (S3-compatible storage) ---
STORAGE_BUCKET=scivision
STORAGE_ENDPOINT=https://sgp1.digitaloceanspaces.com
STORAGE_REGION=sgp1
STORAGE_ACCESS_KEY_ID=your-spaces-key
STORAGE_SECRET_ACCESS_KEY=your-spaces-secret
# Public CDN base (must match your Space CDN URL)
STORAGE_PUBLIC_BASE_URL=https://scivision.sgp1.cdn.digitaloceanspaces.com
STORAGE_OBJECT_ACL=public-read

# --- Optional aliases (app also reads these) ---
# DIGITALOCEAN_SPACES_BUCKET=
# DIGITALOCEAN_SPACES_ENDPOINT=
# DIGITALOCEAN_SPACES_REGION=
# DIGITALOCEAN_SPACES_KEY=
# DIGITALOCEAN_SPACES_SECRET=
# DIGITALOCEAN_SPACES_CDN_URL=
